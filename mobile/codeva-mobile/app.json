{
  "expo": {
    "name": "Codeva",
    "slug": "codeva-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "codeva",
    "primaryColor": "#C96442",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codeva.chat",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Codeva uses the camera so you can snap a photo and ask the AI about it.",
        "NSPhotoLibraryUsageDescription": "Codeva needs photo access so you can attach images to your chat.",
        "NSMicrophoneUsageDescription": "Codeva uses the microphone for voice conversations with the AI.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.codeva.chat",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F14"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Codeva needs photo access so you can attach images to your chat.",
          "cameraPermission": "Codeva uses the camera so you can snap a photo and ask the AI about it."
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
