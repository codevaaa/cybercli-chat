# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Security
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cybercli

# Redis (Upstash or self-hosted)
REDIS_URL=redis://localhost:6379

# AI Provider API Keys
OPENROUTER_API_KEY=your-openrouter-key
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
CEREBRAS_API_KEY=your-cerebras-key
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_KEY=your-cloudflare-key
HUGGINGFACE_API_KEY=your-hf-key
BYTEZ_API_KEY=your-bytez-key
NVIDIA_API_KEY=your-nvidia-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_MAX_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cybermindcli@cybermindcli.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=cybermindcli@cybermindcli.com

# Cloudflare R2 CDN (Installer Downloads)
# Get these from Cloudflare Dashboard → R2 → Manage API Tokens
R2_ENABLED=false
R2_BUCKET_NAME=cybercli-downloads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<your-access-key-id>
R2_SECRET_ACCESS_KEY=<your-secret-access-key>
R2_PUBLIC_URL=https://cdn.cybercli.com

# GitHub Actions only (for CI upload to R2)
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>

