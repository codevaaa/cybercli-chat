# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Admin (comma-separated Supabase user IDs who can ban/manage users)
ADMIN_USER_IDS=your-supabase-user-id-here

# Security
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cybercli

# Redis (Upstash or self-hosted)
REDIS_URL=redis://localhost:6379

# AI Provider API Keys — KEY ROTATION POOL
# Add multiple keys per provider for load balancing & rate-limit avoidance.
# Naming: PROVIDER_API_KEY1, PROVIDER_API_KEY2, ... (up to 50 per provider)
# The system rotates round-robin and auto-skips rate-limited keys.
# These are SERVER-SIDE ONLY — never exposed to clients.

GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=
GEMINI_API_KEY1=
GEMINI_API_KEY2=
GEMINI_API_KEY3=
LLM7_API_KEY1=
LLM7_API_KEY2=
LLM7_API_KEY3=
OPENROUTER_API_KEY1=
CEREBRAS_API_KEY1=
MISTRAL_API_KEY1=
NVIDIA_API_KEY1=
HUGGINGFACE_API_KEY1=
BYTEZ_API_KEY1=
OPENCODE_API_KEY1=
APIFREELLM_API_KEY1=
CLOUDFLARE_API_KEY1=
CLOUDFLARE_API_KEY2=
CLOUDFLARE_API_KEY3=
CLOUDFLARE_ACCOUNT_ID=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_MAX_PRICE_ID=price_...
STRIPE_MAX_YEARLY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cybermindcli@cybermindcli.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=cybermindcli@cybermindcli.com

# E2B Cloud Sandbox (for cloud-based security tool execution — cross-platform)
# Get free API key at: https://e2b.dev
E2B_API_KEY=

# After running: e2b template create codeva-hunter-v1 in hunter-engine/e2b/
# Template is pre-built with 300+ security tools — sandboxes start in <5 sec
# Run: e2b template list  to get your template ID
E2B_SANDBOX_TEMPLATE_ID=40lwmil75yu1t3cdcfjs
# Get these from Cloudflare Dashboard → R2 → Manage API Tokens
R2_ENABLED=false
R2_BUCKET_NAME=cybercli-downloads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<your-access-key-id>
R2_SECRET_ACCESS_KEY=<your-secret-access-key>
R2_PUBLIC_URL=https://cdn.cybercli.com

# GitHub Actions only (for CI upload to R2)
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>

